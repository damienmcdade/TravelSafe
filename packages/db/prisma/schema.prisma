// =============================================================================
// CommunitySafe Prisma schema
//
// HARD RULES (enforced by absence — do not add fields here):
//   * NO demographic fields anywhere (ethnicity, gender, sexual orientation,
//     religion, age). Period.
//   * NO "individual threat" entity. Threats are derived per-area from
//     external crime feeds, not stored per-person.
//   * Posts MUST be tied to an Area (neighborhood), never to a street address.
//     Address-shaped or person-name + accusation text is rejected by the
//     pre-vetter before reaching the DB.
//   * Personal-safety artifacts (SOS events, check-in timers, live shares)
//     are scoped strictly to the owning user and their trusted contacts.
// =============================================================================

// Prisma 7 — the `prisma-client-js` generator is gone; the new `prisma-client`
// generator emits TypeScript into an explicit `output` dir (no more
// node_modules/.prisma magic). This monorepo has three independent consumers
// with their own build roots, so we emit one client per consumer rather than
// share a single one across the ESM/CJS boundary. `moduleFormat` controls
// __dirname (cjs) vs import.meta.url (esm) for locating the JS query compiler.
//   - db  : ESM package, consumes its own client in src/index.ts + seed
//   - api : ESM package (type:module, tsc → ESM), relative imports
//   - web : CJS package built by Next (bundles), uses the @/ path alias
// crime-data is intentionally NOT a consumer — it only ever needed the
// CrimeCategory enum, which is now a local const (packages/crime-data is
// decoupled from Prisma entirely).
// importFileExtension = "js" — the ESM consumers (db, api) are compiled by
// plain tsc (moduleResolution Bundler, which does NOT rewrite import paths) and
// run on node's native ESM loader, which REQUIRES file extensions on relative
// imports. Without this the generated client's own internal imports
// (`./internal/class`, `./enums`) are extensionless and crash at startup with
// ERR_MODULE_NOT_FOUND. The "js" extension makes the generated code import
// `./internal/class.js`, runnable directly after tsc.
generator db_client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  runtime             = "nodejs"
  importFileExtension = "js"
}

generator api_client {
  provider            = "prisma-client"
  output              = "../../../apps/api/src/generated/prisma"
  moduleFormat        = "esm"
  runtime             = "nodejs"
  importFileExtension = "js"
}

generator web_client {
  provider     = "prisma-client"
  output       = "../../../apps/web/src/generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

// Prisma 7 no longer allows `url` in the datasource block — the connection
// string moves to prisma.config.ts (used by Migrate/CLI) and the runtime
// connection is supplied via the @prisma/adapter-pg driver adapter passed to
// each `new PrismaClient({ adapter })`.
datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Identity
// -----------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  displayName   String?
  // NO demographic fields. Do not add age, gender, ethnicity, etc.

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Soft-suspension fields driven by the moderation pipeline.
  suspendedUntil    DateTime?
  permanentlyBanned Boolean   @default(false)

  // v96 — soft-delete for the GDPR / CCPA "right to be forgotten"
  // path. The prior model deleted the User row outright, which
  // cascaded across every relation in this schema and made
  // accidental-click recovery impossible. Now the account API marks
  // deletedAt + obfuscates personally identifiable columns; every
  // User read filters `deletedAt IS NULL` so the row is invisible
  // to the rest of the app. A separate retention worker pass (out
  // of scope here) hard-deletes any row with deletedAt older than
  // the configured grace window.
  deletedAt         DateTime?

  // v92 — account lockout for failed-auth burst protection (DISA STIG
  // AC-7 / NIST 800-53 AC-7). Login service increments failedAttempts
  // on bad password; at 5 fails sets lockedUntil = now + 15 min and
  // rejects with 423 LOCKED until expiry. Successful login resets both.
  // Prevents distributed dictionary attack that the per-IP rate
  // limiter can't catch.
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?

  // v93p2 — JWT revocation cursor. Incremented on logout / password
  // change / explicit revoke; access tokens carry the version they
  // were minted at, and the auth middleware rejects any token whose
  // version is below the current value. Makes JWTs revocable without
  // a session-store (DISA STIG IA-2, AC-12).
  tokenVersion      Int       @default(0)

  // v93p2 — MFA (TOTP). mfaSecret is the base32-encoded shared secret;
  // mfaEnabled flips true once the user successfully verifies a code
  // during enrollment. Storage is plaintext in DB intentionally —
  // anyone with DB access already owns the password hashes; TOTP
  // secret confidentiality buys nothing over that. Standard practice
  // (auth0, Supabase, etc.) is identical. For higher-trust deployments,
  // move to envelope encryption with a KMS key.
  mfaEnabled        Boolean   @default(false)
  mfaSecret         String?

  // Trusted-contributor system. Derived from verified-post count + low
  // rejection rate, and promotable by a moderator. The badge surfaces
  // next to the author name in community feeds so readers can weigh
  // a NEW contributor's claim against a TRUSTED contributor's. We do
  // NOT use these levels for ranking or visibility — every verified
  // post is shown to the same audience; the badge is informational
  // only. trustVerifiedAt is set on first promotion to TRUSTED; cleared
  // on suspension and recomputed thereafter.
  trustLevel        TrustLevel @default(NEW)
  trustVerifiedAt   DateTime?

  alertPreference   AlertPreference?
  trustedContacts   TrustedContact[]
  posts             Post[]            @relation("PostAuthor")
  postReviews       Post[]            @relation("PostReviewer")
  postEdits         PostEdit[]
  postComments      PostComment[]
  postReactions     PostReaction[]
  reportsFiled      PostReport[]      @relation("ReportFiler")
  blockedBy         UserBlock[]       @relation("Blocker")
  blocking          UserBlock[]       @relation("Blocked")
  mutes             UserMute[]        @relation("Muter")
  mutedBy           UserMute[]        @relation("Muted")
  acknowledgements  PostAcknowledgement[]
  pushSubscriptions PushSubscription[]
  checkInTimers     CheckInTimer[]
  liveShareLinks    LiveShareLink[]
  savedPlaces       SavedPlace[]
  reviewActions     PostReviewAction[]
  suspensionEvents  SuspensionEvent[]
  securityAudits    SecurityAuditLog[]  @relation("UserSecurityAudits")

  // "List TRUSTED users", "list new MODERATORs this week" etc.
  // queries become point lookups instead of seq scans. Finding #3
  // in docs/schema-review.md.
  @@index([trustLevel])
  // v96 — every authenticated read filters `deletedAt IS NULL`. Index
  // is sparse (most rows have deletedAt = null) so the planner uses it
  // to short-circuit the soft-delete check.
  @@index([deletedAt])
}

// -----------------------------------------------------------------------------
// Saved Places — "Alert Zones" (proximity safety alerts, à la Citizen)
// -----------------------------------------------------------------------------

/// A place a registered user cares about (home, work, a relative's address).
/// The proximity worker checks recent incidents within `radiusM` and pushes a
/// safety alert when something new appears nearby. lastAlertAt + lastSeenIncidentAt
/// dedupe so the user isn't re-notified about incidents they've already heard about.
model SavedPlace {
  id                 String   @id @default(cuid())
  userId             String
  label              String   // "Home", "Work", "Mom's"
  lat                Float
  lng                Float
  radiusM            Int      @default(800)   // alert radius in meters (~½ mile)
  alertsEnabled      Boolean  @default(true)
  lastAlertAt        DateTime?                // last time we pushed an alert for this place
  lastSeenIncidentAt DateTime?                // newest incident timestamp we've already alerted on
  // fix(audit safezone-proximity-occurredat-lag-miss): freshness keyed on a
  // bounded set of already-seen incident IDs, not just a high-water occurredAt.
  // Feeds publish out of order (a record can surface today dated weeks ago); the
  // timestamp baseline would step over it, the ID set won't.
  seenIncidentIds    String[] @default([])
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // fix(audit perf-savedplace-index): the proximity worker scans
  // `where: { alertsEnabled: true }` every 5 minutes; index it so the tick is a
  // ranged read rather than a full SavedPlace table scan as the table grows.
  @@index([alertsEnabled])
}

// -----------------------------------------------------------------------------
// Onboarding preferences
// -----------------------------------------------------------------------------

/// NIBRS / CIBRS top-level crime groupings. These are CATEGORIES, never people.
enum CrimeCategory {
  PERSONS    // crimes against persons
  PROPERTY   // crimes against property
  SOCIETY    // crimes against society / other
}

/// Notification cadence — defaults to a daily digest to counter notification
/// fatigue and the fear feedback loop. REAL_TIME is opt-in and capped at the
/// service layer.
enum NotificationFrequency {
  DIGEST_DAILY
  REAL_TIME
}

/// Contributor trust level shown as a badge next to author names in
/// community feeds. NOT used for visibility/ranking — informational only.
/// Promotions happen via the trust-recompute job (or moderator override
/// to TRUSTED / MODERATOR).
enum TrustLevel {
  NEW         // <3 verified posts, default for new accounts
  REGULAR     // 3+ verified posts, low rejection rate (auto-promoted)
  TRUSTED     // 10+ verified, very low rejection rate, manual or auto promotion
  MODERATOR   // can verify/reject posts
}

model AlertPreference {
  id          String          @id @default(cuid())
  userId      String          @unique
  categories  CrimeCategory[]
  // Risk threshold above which a notification fires: 1 (any) .. 5 (severe only).
  pushMinRiskLevel      Int                   @default(3)
  notificationFrequency NotificationFrequency @default(DIGEST_DAILY)
  // Hard daily ceiling on push notifications (the API caps at 10 regardless).
  notificationDailyCap  Int                   @default(3)

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Trusted contacts (Personal Safety tab) — max 5 enforced in the service layer.
// Each contact must CONFIRM via an opt-in link before being eligible to receive
// any check-in or live-share notification. Unconfirmed contacts are excluded
// from delivery and shown as such in the UI.
// -----------------------------------------------------------------------------

enum ContactStatus {
  PENDING
  CONFIRMED
  REVOKED
}

model TrustedContact {
  id                  String        @id @default(cuid())
  userId              String
  label               String        // e.g. "Mom", "Roommate"
  email               String?       // at least one of email/phone is required (service-layer check)
  phone               String?
  status              ContactStatus @default(PENDING)
  confirmationToken   String?       @unique
  confirmationSentAt  DateTime?
  confirmedAt         DateTime?
  // v92 — required affirmative consent from the adder that the contact
  // has agreed to be notified. Privacy policy promised we capture this;
  // the field gives us an audit trail. Service layer rejects creates
  // without permissionAcknowledged=true.
  permissionAcknowledged Boolean @default(false)
  createdAt           DateTime      @default(now())

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Areas (neighborhoods / SDPD beats). Posts attach to these, not to addresses.
// -----------------------------------------------------------------------------

enum AreaKind {
  NEIGHBORHOOD
  BEAT
  JURISDICTION
}

model Area {
  id          String    @id @default(cuid())
  slug        String    @unique // e.g. "pacific-beach"
  name        String              // e.g. "Pacific Beach"
  kind        AreaKind
  parentSlug  String?             // e.g. "san-diego" jurisdiction
  centroidLat Float?
  centroidLng Float?

  posts       Post[]

  // City-page queries filter by parentSlug; without this index every
  // city page does a seq scan as the area table grows toward the full
  // 30-city / 5k-neighborhood rollout. Finding #1 in docs/schema-review.md.
  @@index([parentSlug])
  // v88 — neighborhood.routes.ts filters by `kind` (NEIGHBORHOOD vs
  // JURISDICTION) on every list query. Without the index Postgres
  // does a full scan as the area table approaches 5k rows.
  @@index([kind])
}

// -----------------------------------------------------------------------------
// Community posts + verification workflow
// -----------------------------------------------------------------------------

enum PostStatus {
  PENDING       // submitted, awaiting review
  NEEDS_EDITS   // returned to author with reason
  VERIFIED      // visible in feeds
  REJECTED      // never visible
}

/// CommunitySafe post categories. These are intentionally original names —
/// do not mirror Ring/Nextdoor/Citizen taxonomy.
enum PostKind {
  HEADS_UP        // suspicious activity / something off
  AREA_HAZARD     // environmental or infrastructure hazard
  LOST_FOUND      // lost or found item / pet (no people)
  SAFETY_NOTICE   // general safety information for the area
}

enum PostFlagKind {
  PROFANITY
  ADDRESS_DETECTED
  PHONE_DETECTED
  PLATE_DETECTED
  NAME_AND_ACCUSATION
  THREAT_LANGUAGE
  DUPLICATE
  RATE_LIMITED
  TOO_SHORT
  TOO_LONG
  // Anti-profiling: post leads with or hinges on a person's physical /
  // demographic traits rather than behavior or place.
  PROFILING_BY_APPEARANCE
}

enum ReactionKind {
  HELPFUL
  CONFIRMED   // I saw this too
  CONCERNED
}

model Post {
  id              String     @id @default(cuid())
  authorId        String
  areaId          String     // REQUIRED — posts are area-level, never address-level
  kind            PostKind
  body            String     @db.Text
  // Optional attached photo (Ring-Neighbors-style "caught on camera"). Stored
  // as a Vercel Blob URL; null when the post is text-only.
  imageUrl        String?
  status          PostStatus @default(PENDING)

  reviewedAt      DateTime?
  reviewerId      String?
  rejectionReason String?

  reportCount     Int        @default(0)

  // Soft-delete column. Set instead of hard-deleting so the
  // moderator audit trail (PostReviewAction, PostReport) stays
  // intact. Adapters that surface posts to users filter where
  // deletedAt IS NULL. Finding #5 in docs/schema-review.md.
  deletedAt       DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  author          User       @relation("PostAuthor", fields: [authorId], references: [id])
  reviewer        User?      @relation("PostReviewer", fields: [reviewerId], references: [id])
  area            Area       @relation(fields: [areaId], references: [id])

  flags           PostFlag[]
  edits           PostEdit[]
  reports         PostReport[]
  reviewActions   PostReviewAction[]
  acknowledgement PostAcknowledgement?
  comments        PostComment[]
  reactions       PostReaction[]

  @@index([areaId, status])
  @@index([authorId, status])
  @@index([status, createdAt])
  // Moderator queue sorts flagged posts by reportCount DESC. Finding #6.
  @@index([status, reportCount])
  // v88 — every feed query filters `deletedAt IS NULL` for soft-delete.
  // Without the index Postgres can't short-circuit on the rare deleted
  // row and falls back to a heap scan over all posts.
  @@index([deletedAt])
  // v96 — moderator dashboards filter by reviewerId (e.g., "posts
  // reviewed by me this week"). FK was unindexed.
  @@index([reviewerId])
}

model PostComment {
  id        String     @id @default(cuid())
  postId    String
  authorId  String
  body      String     @db.Text
  status    PostStatus @default(PENDING)
  createdAt DateTime   @default(now())

  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id])

  @@index([postId, status])
  // Finding #4: "my comments" view filters by authorId — currently
  // a seq scan. Composite with createdAt for the chronological order.
  @@index([authorId, createdAt])
}

model PostReaction {
  id        String       @id @default(cuid())
  postId    String
  userId    String
  kind      ReactionKind
  createdAt DateTime     @default(now())

  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])

  @@unique([postId, userId, kind])
  @@index([postId])
  // v96 — "my reactions" query (and future per-user moderation
  // surfaces) filter by userId alone; the unique covers (postId,
  // userId, kind) but Postgres can't use that prefix-less for a
  // single-column userId scan. Add the explicit index.
  @@index([userId])
}

model PostFlag {
  id        String       @id @default(cuid())
  postId    String
  kind      PostFlagKind
  detail    String?
  createdAt DateTime     @default(now())

  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

/// Immutable record of every body change — verified posts cannot be silently rewritten.
model PostEdit {
  id          String   @id @default(cuid())
  postId      String
  editorId    String
  previousBody String  @db.Text
  newBody     String   @db.Text
  reason      String?
  createdAt   DateTime @default(now())

  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  editor      User     @relation(fields: [editorId], references: [id])

  @@index([postId])
  // v96 — moderator "edits by user X" query filters by editorId; FK
  // without index made it a full table scan.
  @@index([editorId])
}

/// Submission-time defamation/accuracy acknowledgement — required before insert.
model PostAcknowledgement {
  id           String   @id @default(cuid())
  postId       String   @unique
  userId       String
  acceptedAt   DateTime @default(now())
  acceptedText String   @db.Text  // exact wording the user agreed to (for audit)

  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id])
}

model PostReport {
  id        String   @id @default(cuid())
  postId    String
  reporterId String
  reason    String?
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter  User     @relation("ReportFiler", fields: [reporterId], references: [id])

  @@unique([postId, reporterId])
  @@index([postId])
}

enum ReviewActionKind {
  VERIFY
  REJECT
  REQUEST_EDITS
  REVERT_TO_PENDING
}

/// Immutable moderator decision log — append-only.
model PostReviewAction {
  id         String           @id @default(cuid())
  postId     String
  reviewerId String
  kind       ReviewActionKind
  reason     String?
  // Moderator confirmed the post is area-level and names no individual.
  confirmedAreaLevelAndAnonymized Boolean @default(false)
  createdAt  DateTime         @default(now())

  post       Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  reviewer   User @relation(fields: [reviewerId], references: [id])

  @@index([postId])
  @@index([reviewerId, createdAt])
}

// -----------------------------------------------------------------------------
// Social safety primitives (block / mute)
// -----------------------------------------------------------------------------

model UserBlock {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  createdAt  DateTime @default(now())

  blocker    User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked    User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  // Reverse-direction index — "has this user been blocked by anyone?"
  // runs on every authenticated community feed render. Finding #2.
  @@index([blockedId])
  // v96 — forward "who have I blocked?" surface (Settings → blocks)
  // would otherwise scan UserBlock; small table now, but cheap to
  // keep the FK indexed before it grows.
  @@index([blockerId])
}

model UserMute {
  id        String   @id @default(cuid())
  muterId   String
  mutedId   String
  createdAt DateTime @default(now())

  muter     User     @relation("Muter", fields: [muterId], references: [id], onDelete: Cascade)
  muted     User     @relation("Muted", fields: [mutedId], references: [id], onDelete: Cascade)

  @@unique([muterId, mutedId])
  @@index([mutedId])
}

// -----------------------------------------------------------------------------
// Suspension events (driven by per-user rejection rate threshold)
// -----------------------------------------------------------------------------

enum SuspensionKind {
  TEMPORARY
  PERMANENT
  LIFTED
}

model SuspensionEvent {
  id        String         @id @default(cuid())
  userId    String
  kind     SuspensionKind
  reason    String?
  until     DateTime?
  createdAt DateTime       @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// v92 — security-event audit log (DISA STIG AU-2, AU-3). Captures
// auth successes/failures, moderation decisions, account lifecycle
// (export/delete), permission changes. Written via the
// `writeSecurityAudit()` helper in apps/api so any new auth or
// moderation surface that forgets to call it shows up as a
// coverage gap in the audit-log dashboards.
//
// `userId` is nullable so we can record failed-login attempts against
// non-existent emails without orphaning records. `ip` and `userAgent`
// are stored short-term for forensics; rotate via a retention job
// (90d default) — pending operator decision on retention policy.
model SecurityAuditLog {
  id        String   @id @default(cuid())
  event     String   // 'auth.login.success' | 'auth.login.fail.bad_password' | 'auth.login.fail.locked' | 'auth.register' | 'account.export' | 'account.delete' | 'moderation.review' | 'moderation.suspend' etc.
  userId    String?
  email     String?
  ip        String?
  userAgent String?
  detail    Json?
  createdAt DateTime @default(now())

  user      User? @relation("UserSecurityAudits", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Push notifications (Web Push)
// -----------------------------------------------------------------------------

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  // FCM/APNs endpoints fit comfortably in ~1KB; cap at VARCHAR(2048)
  // so the planner can use length stats. Finding #8 in
  // docs/schema-review.md. Applied with --accept-data-loss because
  // Prisma flags the Text→VarChar narrowing as potentially lossy
  // even though every real-world endpoint is far under the cap.
  endpoint  String   @unique @db.VarChar(2048)
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Personal Safety artifacts
// -----------------------------------------------------------------------------

enum CheckInStatus {
  ACTIVE
  CANCELLED
  TRIGGERED
}

model CheckInTimer {
  id           String        @id @default(cuid())
  userId       String
  scheduledFor DateTime
  message      String?
  cancelToken  String        @unique
  status       CheckInStatus @default(ACTIVE)
  // Last known location captured when timer was set.
  lastLat      Float?
  lastLng      Float?
  createdAt    DateTime      @default(now())
  triggeredAt  DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, scheduledFor])
}

model LiveShareLink {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// NOTE: There is intentionally NO SosEvent / alert-dispatch model. Per the
// product spec, the app does not contact emergency services or trusted contacts
// on the user's behalf in an emergency — the Personal Safety tab only surfaces
// guidance to call 911 directly via a device-native dial action.
