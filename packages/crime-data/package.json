{
  "name": "@travelsafe/crime-data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./src/types.ts"
    },
    "./neighborhoods": {
      "types": "./dist/neighborhoods.d.ts",
      "import": "./dist/neighborhoods.js",
      "default": "./src/neighborhoods.ts"
    },
    "./population": {
      "types": "./dist/population.d.ts",
      "import": "./dist/population.js",
      "default": "./src/population.ts"
    },
    "./fbi-baselines": {
      "types": "./dist/fbi-baselines.d.ts",
      "import": "./dist/fbi-baselines.js",
      "default": "./src/fbi-baselines.ts"
    },
    "./cities": {
      "types": "./dist/cities.d.ts",
      "import": "./dist/cities.js",
      "default": "./src/cities.ts"
    },
    "./city-states": {
      "types": "./dist/city-states.d.ts",
      "import": "./dist/city-states.js",
      "default": "./src/city-states.ts"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "default": "./src/errors.ts"
    },
    "./cache-registry": {
      "types": "./dist/cache-registry.d.ts",
      "import": "./dist/cache-registry.js",
      "default": "./src/cache-registry.ts"
    },
    "./safety-score": {
      "types": "./dist/safety-score.d.ts",
      "import": "./dist/safety-score.js",
      "default": "./src/safety-score.ts"
    },
    "./trend-feed": {
      "types": "./dist/trend-feed.d.ts",
      "import": "./dist/trend-feed.js",
      "default": "./src/trend-feed.ts"
    },
    "./mix": {
      "types": "./dist/mix.d.ts",
      "import": "./dist/mix.js",
      "default": "./src/mix.ts"
    },
    "./upticks": {
      "types": "./dist/upticks.d.ts",
      "import": "./dist/upticks.js",
      "default": "./src/upticks.ts"
    },
    "./dispatcher": {
      "types": "./dist/dispatcher.d.ts",
      "import": "./dist/dispatcher.js",
      "default": "./src/dispatcher.ts"
    },
    "./polygon-areas": {
      "types": "./dist/polygon-areas.d.ts",
      "import": "./dist/polygon-areas.js",
      "default": "./src/polygon-areas.ts"
    },
    "./neighborhood-population": {
      "types": "./dist/neighborhood-population.d.ts",
      "import": "./dist/neighborhood-population.js",
      "default": "./src/neighborhood-population.ts"
    },
    "./lib/http": {
      "types": "./dist/lib/http.d.ts",
      "import": "./dist/lib/http.js",
      "default": "./src/lib/http.ts"
    },
    "./lib/inflight": {
      "types": "./dist/lib/inflight.d.ts",
      "import": "./dist/lib/inflight.js",
      "default": "./src/lib/inflight.ts"
    },
    "./lib/city-time": {
      "types": "./dist/lib/city-time.d.ts",
      "import": "./dist/lib/city-time.js",
      "default": "./src/lib/city-time.ts"
    },
    "./lib/freshness": {
      "types": "./dist/lib/freshness.d.ts",
      "import": "./dist/lib/freshness.js",
      "default": "./src/lib/freshness.ts"
    },
    "./adapters/*": {
      "types": "./dist/adapters/*.d.ts",
      "import": "./dist/adapters/*.js",
      "default": "./src/adapters/*.ts"
    },
    "./data/*": {
      "types": "./dist/data/*.d.ts",
      "import": "./dist/data/*.js",
      "default": "./src/data/*.ts"
    },
    "./data/*.json": "./src/data/*.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/data && cp -R src/data/*.json dist/data/ 2>/dev/null || true",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
