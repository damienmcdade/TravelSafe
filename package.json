{
  "name": "travelsafe",
  "private": true,
  "version": "0.1.0",
  "description": "Personal and community safety-awareness app for the San Diego region.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace apps/web",
    "build:api": "npm run build --workspace apps/api",
    "start:web": "npm run start --workspace apps/web",
    "start:api": "npm run start --workspace apps/api",
    "db:generate": "npm run prisma:generate --workspace packages/db",
    "db:migrate": "npm run prisma:migrate --workspace packages/db",
    "db:migrate:deploy": "npm run prisma:migrate:deploy --workspace packages/db",
    "db:push": "npm run prisma:db:push --workspace packages/db",
    "db:seed": "npm run seed --workspace packages/db",
    "db:studio": "npm run prisma:studio --workspace packages/db",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/api/**/*.ts": [
      "bash -c 'cd apps/api && npx eslint --fix'"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "bash -c 'cd apps/web && npx eslint --fix'"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  },
  "_comment_optionalDependencies": "npm bug #4828: the lockfile only records the rollup native-binary node for the platform it was generated on (macOS arm64), so `npm ci` on the Linux CI runner can't install @rollup/rollup-linux-x64-gnu and vitest fails. Declaring it as a direct optionalDependency forces a proper lockfile node; the os/cpu fields make npm skip it on non-Linux hosts. Keep the version pinned to the resolved rollup version (rollup loads the native binary by exact-version match).",
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.61.1"
  },
  "engines": {
    "node": "22.x"
  }
}
