{
  "name": "@travelsafe/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf src/generated/prisma && npx -y prisma@7.8.0 generate --schema=../../packages/db/prisma/schema.prisma && tsc -p tsconfig.json",
    "_start_notes": "max-old-space-size=3584 = 3.5 GB, sized for Railway's ~4 GB container. Holds steady-state adapter cache + Redis client + concurrent request buffers. Tune down if deployed to a smaller container. --expose-gc enables global.gc() at warm-worker cycle boundaries to release the per-cycle row buffers; see services/warm/cache.worker.ts.",
    "start": "node --expose-gc --max-old-space-size=3584 dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/groq": "^3.0.39",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^8.55.2",
    "@travelsafe/crime-data": "*",
    "@travelsafe/db": "*",
    "ai": "^6.0.195",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "nodemailer": "^8.0.10",
    "otplib": "^13.4.1",
    "pg": "^8.13.1",
    "rate-limit-redis": "^4.3.1",
    "undici": "^7.27.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.20.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.10",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
