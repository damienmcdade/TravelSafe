# TravelSafe local-dev environment variables.
#
# Copy to `.env.local` and fill in the values you need. EVERYTHING is
# optional for browsing the app — most adapters work with public-data
# defaults — but a few features need a real value:
#
#   DATABASE_URL  → Required for CommunitySafe posts, Check-In timer,
#                   Live Share, trusted contacts. Without it, those
#                   endpoints throw 500 in local dev (the rest of the
#                   app — Crime Map, Awareness, SafeZone, Trend Feed,
#                   Personal Safety tips — works fine without a DB).
#
#   GROQ_API_KEY  → Required for the AI Assistant chat. Free key at
#   or            https://console.groq.com/keys (Llama 3.3 70B) or
#   GOOGLE_GEN_AI_API_KEY https://aistudio.google.com/app/apikey (Gemini).
#                   Without either, the assistant panel shows a
#                   disabled-state message but the rest of the app
#                   still works.
#
#   CRON_SECRET   → Optional. When set, /api/cron/* endpoints
#                   require Authorization: Bearer <secret>. Vercel
#                   Cron automatically attaches this. Local dev can
#                   omit; the cron endpoints are public if unset.

# ─── Database (Postgres) ───────────────────────────────────────────
# DATABASE_URL=postgres://user:pass@host:5432/travelsafe

# ─── Auth ──────────────────────────────────────────────────────────
# JWT_SECRET=  # random 64+ char string; required only if you use the legacy account flow
# JWT_EXPIRES_IN=7d
# BCRYPT_ROUNDS=12

# ─── Police data adapter overrides ─────────────────────────────────
# Most adapters use baked-in URLs. SDPD's SANDAG and CSV bases are
# configurable here in case the upstream feed moves.
# SANDAG_SOCRATA_BASE=https://data.sandiegocounty.gov
# SANDAG_CRIME_RATES_RESOURCE_ID=486f-q228
# SANDAG_SOCRATA_APP_TOKEN=  # optional Socrata token for higher rate limits
# SDPD_NIBRS_CSV_BASE=https://seshat.datasd.org/police_nibrs
# BOSTON_PROXY_URL=  # optional Cloudflare Worker if data.boston.gov rejects Vercel IPs

# ─── Push notifications (VAPID) ────────────────────────────────────
# Required only if you enable web-push from the Awareness tab.
# Generate with `npx web-push generate-vapid-keys`
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@yourdomain.com

# ─── Live Share + SMS (optional) ───────────────────────────────────
# LIVE_SHARE_BASE_URL=http://localhost:3000
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15555550100

# ─── Email (optional) ──────────────────────────────────────────────
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# NOTIFY_EMAIL_FROM=alerts@yourdomain.com

# ─── Cron auth ─────────────────────────────────────────────────────
# CRON_SECRET=  # any non-empty string; Vercel Cron passes this as Bearer token

# ─── AI Assistant providers (need ONE) ─────────────────────────────
# GROQ_API_KEY=  # Llama 3.3 70B via Groq — fastest, free tier generous
# GOOGLE_GENERATIVE_AI_API_KEY=  # Gemini — also free tier
# AI_GATEWAY_API_KEY=  # Vercel AI Gateway (alternative)

# ─── Check-in timer behavior ───────────────────────────────────────
# CHECKIN_GRACE_SECONDS=120  # how long after a timer expires before contacts are notified

# ─── Moderator allowlist (optional) ────────────────────────────────
# MODERATOR_EMAILS=a@x.com,b@y.com  # comma-separated emails granted moderation actions
