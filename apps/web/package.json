{
  "name": "@travelsafe/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "icons:generate": "node scripts/generate-communitysafe-icons.mjs",
    "build": "npm run build --workspace=@travelsafe/crime-data && npx -y prisma@7.8.0 generate --schema=../../packages/db/prisma/schema.prisma && next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "mobile:sync": "npx cap sync",
    "mobile:ios": "npx cap sync ios && npx cap open ios",
    "mobile:android": "npx cap sync android && npx cap open android",
    "mobile:android:aab": "cd android && JAVA_HOME=/opt/homebrew/Cellar/openjdk@21/21.0.11/libexec/openjdk.jdk/Contents/Home ./gradlew bundleRelease",
    "mobile:android:apk": "cd android && JAVA_HOME=/opt/homebrew/Cellar/openjdk@21/21.0.11/libexec/openjdk.jdk/Contents/Home ./gradlew assembleRelease",
    "mobile:ios:build": "xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Debug -sdk iphonesimulator -destination 'platform=iOS Simulator,name=iPhone 17' CODE_SIGNING_ALLOWED=NO"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/groq": "^3.0.39",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@travelsafe/crime-data": "*",
    "@vercel/blob": "^2.4.0",
    "ai": "^6.0.195",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^5.5.6",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "next": "^15.2.3",
    "nodemailer": "^8.0.10",
    "otplib": "^13.4.1",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "server-only": "^0.0.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.4.0",
    "@eslint/eslintrc": "^3.3.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/geojson": "^7946.0.16",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^22.19.21",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.49",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
