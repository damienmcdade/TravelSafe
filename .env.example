# =============================================================================
# TravelSafe — environment variables
#
# Copy to `.env` at the repo root for local development. In production, set
# these in Vercel (web app) and Railway (api + db) project settings.
# NEVER commit a real .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Railway Postgres)
# -----------------------------------------------------------------------------
# Railway provides this automatically as DATABASE_URL on the Postgres plugin.
# Locally, run `docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres`
# or point at a free hosted Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/travelsafe?schema=public"

# -----------------------------------------------------------------------------
# Auth (apps/api)
# -----------------------------------------------------------------------------
# Generate with: `openssl rand -base64 48`
JWT_SECRET="replace-me-with-a-long-random-string"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS="12"

# -----------------------------------------------------------------------------
# API server (apps/api)
# -----------------------------------------------------------------------------
API_PORT="4000"
# Comma-separated list of allowed origins for CORS. In prod include the Vercel URL.
CORS_ORIGINS="http://localhost:3000"

# -----------------------------------------------------------------------------
# Crime-data adapters
# -----------------------------------------------------------------------------
# Primary: San Diego County Open Data Portal (Socrata / SODA)
SANDAG_SOCRATA_BASE="https://data.sandiegocounty.gov"
SANDAG_CRIME_RATES_RESOURCE_ID="486f-q228"
# Optional Socrata app token — raises the rate limit. Get one at
# https://data.sandiegocounty.gov/profile/app_tokens
SANDAG_SOCRATA_APP_TOKEN=""

# Secondary: City of San Diego Open Data — SDPD NIBRS Crime Offenses (CSV)
SDPD_NIBRS_CSV_BASE="https://seshat.datasd.org/police_nibrs"

# Set to "mock" to force the fallback adapter regardless of network state.
CRIME_DATA_ADAPTER="auto"  # auto | sandag | sdpd | mock

# -----------------------------------------------------------------------------
# Web Push (apps/web service worker + apps/api sender)
# -----------------------------------------------------------------------------
# Generate with: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:ops@travelsafe.example"

# Public mirror exposed to the browser by Next.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# -----------------------------------------------------------------------------
# Trusted-contact notifications (Personal Safety tab)
# -----------------------------------------------------------------------------
# Used for:
#   1. The opt-in confirmation link sent to a newly-added trusted contact.
#   2. Check-in timer expiry notifications (last-known location + user note).
#   3. Live-share link delivery to a single chosen contact.
# Default channel is "email" (simplest, no third-party SMS provider needed).
# Set to "sms" only if Twilio creds are filled in below.
TRUSTED_CONTACT_CHANNEL="email"

# Public base URL used to build confirmation + live-share links delivered to
# contacts (e.g. https://travelsafe.example/share/<token>). Falls back to
# NEXT_PUBLIC_APP_URL.
LIVE_SHARE_BASE_URL=""

# Optional Twilio creds (SMS confirmation / check-in delivery). Leave empty to
# stay email-only. The app does NOT use SMS for any emergency dispatch — the
# Personal Safety tab guides users to dial 911 directly via the device.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Email transport (contact confirmation + check-in expiry notifications)
NOTIFY_EMAIL_FROM="alerts@travelsafe.example"
SMTP_URL=""  # e.g. smtps://user:pass@smtp.example.com:465

# -----------------------------------------------------------------------------
# Vercel AI Gateway (composer coach)
# -----------------------------------------------------------------------------
# Optional. When set, the community post composer streams inline coaching
# from anthropic/claude-haiku-4-5 via Vercel AI Gateway. When unset, the
# composer relies only on the local pre-vetter rules (no behavior change).
AI_GATEWAY_API_KEY=""

# -----------------------------------------------------------------------------
# Check-in timer (server-side worker)
# -----------------------------------------------------------------------------
# The Express API runs a polling worker that fires expired check-in timers
# regardless of whether the user's client is open. Interval in seconds.
CHECKIN_WORKER_INTERVAL_SECONDS="30"
# Grace window (seconds) the user has to confirm safety after expiry prompt.
CHECKIN_GRACE_SECONDS="120"

# -----------------------------------------------------------------------------
# Web app (apps/web)
# -----------------------------------------------------------------------------
# Where the browser should call the API. In prod this is your Railway URL.
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Public link-out targets shown by CommunitySafe (no in-app re-display).
NEXT_PUBLIC_SEX_OFFENDER_REGISTRY_URL="https://www.meganslaw.ca.gov/"
NEXT_PUBLIC_EMERGENCY_DIAL="911"
