{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build --workspace apps/web",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/check-in",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/warm-cache",
      "schedule": "*/4 * * * *"
    }
  ]
}
